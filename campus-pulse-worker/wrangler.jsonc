		},
		{
			"binding": "EVENTS_INDEX",
			"id": "7002a1a21a0c43e39b582e256dfd6f41"
		},
		{
			"binding": "EMAILS",
			"id": "5c1adbc5f26a43dd982b52aa1801be32"
		},
		{
			"binding": "USERS",
			"id": "913118715ca54781a04612c731d6bd7a"
		},
		{
			"binding": "SESSIONS",
			"id": "2fd0a51593794f91ba28ddac54507686"
		},
		{
			"binding": "INTERESTS",
			"id": "2524b166e31f46d1925560b950f8c72b"
		},
		{
			"binding": "SECURITY",
			"id": "93c0509f821f42aaa859d17a4059711e"
		}
	]
}
